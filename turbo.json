{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".bun-version", ".oxlintrc.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", ".oxlintrc.json"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "inputs": ["src/**"],
      "outputs": []
    }
  }
}
